# ─── Core ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/rostersyncos?schema=public"
JWT_SECRET="change-me-in-production"
NODE_ENV=development

# ─── API ───────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=3001
CORS_ORIGINS=http://127.0.0.1:3000

# ─── Web ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# ─── Auth ──────────────────────────────────────────────────────
# AUTH_MODE controls authentication enforcement:
#   DEMO   = skip JWT validation, use mock admin user (for demos)
#   (unset) = normal JWT authentication required
AUTH_MODE=DEMO
DEMO_USER_EMAIL=admin@rostersyncos.io
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL=http://localhost:3000

# ─── Redis / BullMQ ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Wix Integration ──────────────────────────────────────────
# WIX_MODE controls sync behavior:
#   STUB   = no real Wix calls (default for dev/demo)
#   LIVE   = real Wix API calls (requires tokens below)
WIX_MODE=STUB
WIX_STUB_FAIL_RATE=0
WIX_STUB_FORCE_FAIL=0
WIX_SITE_ID=
WIX_WEBHOOK_SECRET=
WIX_ACCESS_TOKEN=
WIX_REFRESH_TOKEN=
WIX_APP_INSTANCE_ID=
